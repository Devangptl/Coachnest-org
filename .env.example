# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Pooled connection for app runtime (port 6543, PgBouncer transaction mode)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Canonical origin used in emails, OG metadata, and sitemap. Defaults to
# NEXT_PUBLIC_APP_URL when unset.
NEXT_PUBLIC_APP_ORIGIN="https://coachnest.com"

# Root domain for organization subdomains. In production, <slug>.coachnest.in
# resolves to an org workspace and org.coachnest.in is the platform/main site.
# Requires a wildcard DNS record (*.coachnest.in) pointing at this app. Leave it
# at the default for localhost dev, where there are no subdomains and orgs are
# reached via the path-based /org/[slug] routes.
NEXT_PUBLIC_ROOT_DOMAIN="coachnest.in"

# ─── Admin Migration Runner ───────────────────────────────────────────────────
# Gates the /admin/migrations "Run migrate deploy" button. Read-only status is
# always available to admins; EXECUTION is off unless this is exactly "true".
# Only ever runs `prisma migrate deploy` (never dev/reset/db push/raw SQL).
# Keep this OFF (false/unset) in production except during a controlled deploy.
ENABLE_MIGRATION_RUNNER="false"

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
# Used for payments (courses, books) AND instructor payouts via Razorpay Route.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxx"
# Exposed to browser — KEY_ID only; NEVER expose KEY_SECRET to the client.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
# Instructor payouts use Razorpay Route (same keys above — no separate banking account needed).
# Activate Route: Razorpay Dashboard → Route → Get Started (or contact Razorpay support).
# Webhook secret — set in Razorpay Dashboard → Settings → Webhooks → (your webhook) → Secret.
# Webhook URL: https://yourdomain.com/api/razorpay/webhook
# Events to enable: payment.captured, order.paid, payment.failed
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Coachnest <noreply@yourdomain.com>"

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
# Dashboard: https://console.cloudinary.com
# Provide either CLOUDINARY_URL *or* the three split variables.
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# CLOUDINARY_CLOUD_NAME="your_cloud_name"
# CLOUDINARY_API_KEY="your_api_key"
# CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
