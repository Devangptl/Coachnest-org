# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Pooled connection for app runtime (port 6543, PgBouncer transaction mode)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Admin Migration Runner ───────────────────────────────────────────────────
# Gates the /admin/migrations "Run migrate deploy" button. Read-only status is
# always available to admins; EXECUTION is off unless this is exactly "true".
# Only ever runs `prisma migrate deploy` (never dev/reset/db push/raw SQL).
# Keep this OFF (false/unset) in production except during a controlled deploy.
ENABLE_MIGRATION_RUNNER="false"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Stripe Subscription Price IDs
# Create products & prices at: https://dashboard.stripe.com/products
# One price ID per plan × billing period (monthly / yearly)
STRIPE_PRICE_BASIC_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_BASIC_YEARLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_PRO_YEARLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_ENTERPRISE_YEARLY="price_xxxxxxxxxxxx"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="CoachNest <noreply@yourdomain.com>"

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
# Dashboard: https://console.cloudinary.com
# Provide either CLOUDINARY_URL *or* the three split variables.
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# CLOUDINARY_CLOUD_NAME="your_cloud_name"
# CLOUDINARY_API_KEY="your_api_key"
# CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
