generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  PENDING_REVIEW
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NotifType {
  COURSE_UPDATE
  PURCHASE
  REVIEW
  REMINDER
  OFFER
  SYSTEM
  FORUM_REPLY
  GROUP_INVITE
  PEER_REVIEW
  ACTIVITY
}

enum GroupRole {
  MEMBER
  ADMIN
}

// ─── Organization (Multi-tenant) ──────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  website     String?
  plan        PlanType  @default(FREE)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members OrganizationMember[]
  courses Course[]
  coupons Coupon[]
  payouts Payout[]

  @@map("organizations")
}

model OrganizationMember {
  userId         String
  organizationId String
  role           Role     @default(STUDENT)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("organization_members")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?  // null for Supabase Auth users (password stored in auth.users)
  avatar    String?
  bio       String?  @db.Text
  headline  String?
  website   String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations  OrganizationMember[]
  courses        Course[]             @relation("CourseInstructor")
  enrollments    Enrollment[]
  orders         Order[]
  subscription   Subscription?
  reviews        Review[]
  wishlist       Wishlist[]
  notifications  Notification[]
  certificates   Certificate[]
  quizAttempts   QuizAttempt[]
  lessonProgress LessonProgress[]
  couponUses     CouponUse[]
  highlights     Highlight[]
  blogs          Blog[]           @relation("BlogAuthor")
  gameProfile    UserGameProfile?
  userBadges     UserBadge[]
  xpEvents       XpEvent[]

  // Stripe
  stripeCustomerId String? @unique

  // Tour Flags
  hasSeenTour          Boolean  @default(false)
  hasSeenCommunityTour Boolean  @default(false)

  // Feature add-on purchases
  featurePurchases      FeaturePurchase[]

  // Community
  forumThreads          ForumThread[]
  forumReplies          ForumReply[]
  forumVotes            ForumVote[]
  studyGroups           StudyGroupMember[]
  createdGroups         StudyGroup[]           @relation("GroupCreator")
  peerReviewSubmissions PeerReviewAssignment[]
  peerReviews           PeerReview[]
  activityEvents        ActivityFeedEvent[]
  groupNotes            GroupNote[]

  @@map("users")
}

// ─── Category & Tag ───────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  icon    String?
  color   String?
  courses Course[]

  @@map("categories")
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  courses CourseTag[]

  @@map("tags")
}

model CourseTag {
  courseId String
  tagId    String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

// ─── Course ───────────────────────────────────────────────────────────────────

model Course {
  id                       String        @id @default(cuid())
  title                    String
  slug                     String        @unique
  description              String        @db.Text
  shortDesc                String?
  thumbnail                String?
  previewVideo             String?
  status                   ContentStatus @default(DRAFT)
  price                    Decimal?      @db.Decimal(10, 2)
  discountPrice            Decimal?      @db.Decimal(10, 2)
  isFree                   Boolean       @default(false)
  minPlan                  PlanType      @default(BASIC)
  level                    String        @default("beginner")
  language                 String        @default("English")
  totalDuration            Int           @default(0)
  totalLessons             Int           @default(0)
  // Revenue split: instructor gets this %, platform gets (100 - instructorRevenuePercent)%
  // Configurable per-course (default 70). Valid range: 70–80.
  instructorRevenuePercent Int           @default(70)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  categoryId     String?
  createdById    String
  organizationId String?

  category     Category?     @relation(fields: [categoryId], references: [id])
  createdBy    User          @relation("CourseInstructor", fields: [createdById], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  sections     Section[]
  lessons      Lesson[]
  enrollments  Enrollment[]
  reviews      Review[]
  tags         CourseTag[]
  orders       Order[]
  wishlist     Wishlist[]
  certificates Certificate[]

  @@map("courses")
}

// ─── Section ──────────────────────────────────────────────────────────────────

model Section {
  id       String @id @default(cuid())
  title    String
  order    Int
  courseId String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("sections")
}

// ─── Lesson ───────────────────────────────────────────────────────────────────

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  type        LessonType @default(TEXT)
  content     String?    @db.Text
  order       Int
  duration    Int?
  isFree      Boolean    @default(false)
  publishAt   DateTime?  // drip: null = immediately available

  courseId  String
  sectionId String?

  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section    Section?         @relation(fields: [sectionId], references: [id])
  progress   LessonProgress[]
  quiz          Quiz?
  highlights    Highlight[]
  @@map("lessons")
}

// ─── Enrollment ───────────────────────────────────────────────────────────────

model Enrollment {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  lastLessonId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─── Lesson Progress ──────────────────────────────────────────────────────────

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  watchedSecs Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ─── Quiz & Assessments ───────────────────────────────────────────────────────

model Quiz {
  id        String @id @default(cuid())
  lessonId  String @unique
  title     String
  passMark  Int    @default(70)
  timeLimit Int?

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id      String @id @default(cuid())
  quizId  String
  text    String @db.Text
  options Json
  order   Int
  points  Int    @default(1)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  answers   Json
  timeTaken Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?  @db.Text
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("reviews")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
  @@map("wishlists")
}

// ─── Payment & Subscriptions ──────────────────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  userId            String
  courseId          String?
  // Feature add-on purchase (mutually exclusive with courseId)
  featureId         String?
  amount            Decimal     @db.Decimal(10, 2)
  currency          String      @default("INR")
  status            OrderStatus @default(PENDING)
  stripeSessionId   String?     @unique
  stripePaymentId   String?     @unique
  couponId          String?
  discountAmount    Decimal?    @db.Decimal(10, 2)
  // Revenue attribution (populated on PAID status)
  instructorRevenue Decimal?    @db.Decimal(10, 2)
  platformRevenue   Decimal?    @db.Decimal(10, 2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  course          Course?          @relation(fields: [courseId], references: [id])
  coupon          Coupon?          @relation(fields: [couponId], references: [id])
  feature         PlatformFeature? @relation(fields: [featureId], references: [id])
  featurePurchase FeaturePurchase?

  @@map("orders")
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  plan          PlanType
  status        SubStatus @default(ACTIVE)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  trialEndsAt   DateTime?
  stripeSubId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payout {
  id             String    @id @default(cuid())
  organizationId String
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @default("INR")
  status         String    @default("PENDING")
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("payouts")
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType @default(PERCENTAGE)
  discount       Decimal      @db.Decimal(10, 2)
  maxUses        Int?
  uses           Int          @default(0)
  expiresAt      DateTime?
  courseId       String?
  organizationId String?
  createdAt      DateTime     @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  orders       Order[]
  couponUses   CouponUse[]

  @@map("coupons")
}

model CouponUse {
  userId   String
  couponId String
  usedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  coupon Coupon @relation(fields: [couponId], references: [id])

  @@id([userId, couponId])
  @@map("coupon_uses")
}

// ─── Certificate ──────────────────────────────────────────────────────────────

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  certificateUrl String?
  issuedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String    @db.Text
  type      NotifType @default(SYSTEM)
  read      Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model Blog {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?       @db.Text
  content     String        @db.Text
  thumbnail   String?
  status      ContentStatus @default(DRAFT)
  tags        String?       // comma-separated tags
  readTime    Int?          // estimated reading time in minutes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  authorId String
  author   User @relation("BlogAuthor", fields: [authorId], references: [id])

  @@map("blogs")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model UserGameProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  xp             Int       @default(0)
  level          Int       @default(1)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_game_profiles")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xp        Int
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("xp_events")
}

// ─── Highlight ────────────────────────────────────────────────────────────────

model Highlight {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  text        String   @db.Text
  blockIndex  Int
  startOffset Int
  endOffset   Int
  color       String   @default("#a855f7")
  note        String?  @db.Text
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@map("highlights")
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id          String    @id @default(cuid())
  name        String
  email       String
  subject     String?
  message     String    @db.Text
  status      String    @default("UNREAD") // UNREAD, READ, REPLIED
  adminReply  String?   @db.Text
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("contact_messages")
}

// ─── Community: Discussion Forums ─────────────────────────────────────────────

model ForumThread {
  id         String   @id @default(cuid())
  title      String
  body       String   @db.Text
  courseId   String?
  lessonId   String?
  authorId   String
  isPinned   Boolean  @default(false)
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies ForumReply[]

  @@index([courseId])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumReply {
  id        String   @id @default(cuid())
  body      String   @db.Text
  threadId  String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread  ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  ForumReply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children ForumReply[] @relation("ReplyToReply")
  votes   ForumVote[]

  @@index([threadId])
  @@index([authorId])
  @@map("forum_replies")
}

model ForumVote {
  id      String @id @default(cuid())
  userId  String
  replyId String
  value   Int    // +1 or -1

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@map("forum_votes")
}

// ─── Community: Study Groups ──────────────────────────────────────────────────

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  courseId    String?
  inviteCode  String   @unique
  maxMembers  Int      @default(20)
  isPublic    Boolean  @default(true)
  groupXp     Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User               @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   StudyGroupMember[]
  notes     GroupNote[]

  @@index([courseId])
  @@map("study_groups")
}

model StudyGroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("study_group_members")
}

model GroupNote {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_notes")
}

// ─── Community: Peer Review ───────────────────────────────────────────────────

model PeerReviewAssignment {
  id            String   @id @default(cuid())
  title         String
  content       String   @db.Text
  courseId      String?
  lessonId      String?
  submittedById String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  submittedBy User         @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  reviews     PeerReview[]

  @@index([submittedById])
  @@map("peer_review_assignments")
}

model PeerReview {
  id           String   @id @default(cuid())
  assignmentId String
  reviewerId   String
  rating       Int      // 1-5
  feedback     String   @db.Text
  rubricScores Json?    // { clarity: 4, depth: 3, ... }
  createdAt    DateTime @default(now())

  assignment PeerReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer   User                 @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, reviewerId])
  @@map("peer_reviews")
}

// ─── Community: Activity Feed ─────────────────────────────────────────────────

model ActivityFeedEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String   // BADGE_EARNED, COURSE_COMPLETED, THREAD_CREATED, GROUP_JOINED, REVIEW_SUBMITTED
  title       String
  description String?  @db.Text
  meta        Json?    // extra data (badgeName, courseName, etc.)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_feed_events")
}

// ─── Platform Features (purchasable add-ons) ──────────────────────────────────

model PlatformFeature {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases FeaturePurchase[]
  orders    Order[]

  @@map("platform_features")
}

model FeaturePurchase {
  id          String   @id @default(cuid())
  userId      String
  featureId   String
  // Nullable: allows admin-granted access without an order
  orderId     String?  @unique
  purchasedAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id])
  order   Order?          @relation(fields: [orderId], references: [id])

  @@unique([userId, featureId])
  @@map("feature_purchases")
}

// ─── Launch: Waitlist ─────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("waitlist_entries")
}
