generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// Sub-roles inside ADMIN. Only meaningful when User.role = ADMIN.
// SUPER_ADMIN has full access; others are scoped to a slice of /admin.
enum AdminSubRole {
  SUPER_ADMIN
  CONTENT_ADMIN
  USER_ADMIN
  FINANCE_ADMIN
  SUPPORT
}

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// ─── Organization (multi-tenant) enums ────────────────────────────────────────

// Role inside an organization workspace. Independent of the platform Role —
// a user can hold a platform role and org roles in several orgs at once.
enum OrgRole {
  ORG_OWNER
  ORG_ADMIN
  ORG_MANAGER
  ORG_INSTRUCTOR
  ORG_TA
  ORG_STUDENT
  ORG_OBSERVER
}

enum OrgStatus {
  PENDING // registered, first payment not completed yet
  ACTIVE
  SUSPENDED // platform-admin action
  EXPIRED // subscription lapsed
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum OrgSubscriptionStatus {
  PENDING // created, awaiting first payment
  ACTIVE
  EXPIRED
  CANCELLED // cancelled/refunded by platform admin
}

enum OrgTransactionType {
  SUBSCRIPTION
  RENEWAL
  UPGRADE
  DOWNGRADE
  REFUND
}

enum OrgTransactionStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// Refund state machine on the original transaction (mirrors RefundStatus,
// minus PENDING/REJECTED — org refunds are admin-initiated, no request queue).
enum OrgRefundStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  PENDING_REVIEW
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum OfferScope {
  ALL
  COURSES
  BOOKS
}

enum NotifType {
  COURSE_UPDATE
  PURCHASE
  REVIEW
  REMINDER
  OFFER
  SYSTEM
  FORUM_REPLY
  GROUP_INVITE
  JOIN_REQUEST
  PEER_REVIEW
  ACTIVITY
}

enum SaleSource {
  ORGANIC // discovered via platform
  REFERRAL // student came via instructor's referral link
  COUPON // instructor's own coupon used
  ADS // platform-paid acquisition
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum GroupRole {
  MEMBER
  ADMIN
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RefundStatus {
  PENDING // Student submitted, awaiting admin review
  PROCESSING // Razorpay refund in flight
  PROCESSED // Fully complete — refunded, enrollment revoked, wallet debited
  REJECTED // Admin rejected the request
  FAILED // Razorpay refund failed after approval
}

enum LedgerEntryType {
  PURCHASE // Student paid for course
  PLATFORM_FEE // Platform share on purchase
  INSTRUCTOR_EARNING // Instructor share on purchase
  REFUND // Refund issued to student
  REFUND_REVERSAL_INSTRUCTOR // Instructor share clawed back on refund
  REFUND_REVERSAL_PLATFORM // Platform share clawed back on refund
}

enum InstructorStatus {
  PENDING // Awaiting admin approval
  APPROVED // Approved and active
  REJECTED // Application rejected
}

enum PlaylistVisibility {
  PUBLIC
  PRIVATE
}

enum BookFileFormat {
  PDF
  EPUB
  DOCX
}

// ─── Course Collaboration ─────────────────────────────────────────────────────

enum CourseCollaboratorRole {
  OWNER // primary instructor — created the course (mirrors createdById)
  CO_INSTRUCTOR // full edit, share in revenue, appears on course page
  EDITOR // can edit content but not manage collaborators or split
  VIEWER // read-only access to course internals
}

enum CollaborationInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

// ─── Organization (Multi-tenant) ──────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  email       String?
  phone       String?
  logo        String?
  website     String?
  plan        PlanType  @default(FREE) // legacy — current plan derives from the active subscription
  status      OrgStatus @default(PENDING)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members       OrganizationMember[]
  courses       Course[]
  books         Book[]
  coupons       Coupon[]
  payouts       Payout[]
  subscriptions OrganizationSubscription[]
  transactions  OrganizationTransaction[]

  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  userId         String
  organizationId String
  role           OrgRole  @default(ORG_STUDENT)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([organizationId, role])
  @@map("organization_members")
}

// ─── Organization subscriptions & billing ─────────────────────────────────────

model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?  @db.Text
  priceMonthly   Decimal  @db.Decimal(10, 2)
  priceYearly    Decimal  @db.Decimal(10, 2)
  currency       String   @default("INR")
  maxStudents    Int? // null = unlimited
  maxInstructors Int?
  maxCourses     Int?
  features       Json? // marketing bullets for the pricing card
  isActive       Boolean  @default(true) // soft-archive; never delete (FK from subscriptions)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions OrganizationSubscription[]

  @@map("subscription_plans")
}

model OrganizationSubscription {
  id             String                @id @default(cuid())
  organizationId String
  planId         String
  billingCycle   BillingCycle
  amount         Decimal               @db.Decimal(10, 2) // price locked at purchase time
  currency       String                @default("INR")
  status         OrgSubscriptionStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  cancelledAt    DateTime?

  // Scheduled downgrade — applied when the renewal payment is finalized.
  pendingPlanId       String?
  pendingBillingCycle BillingCycle?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan          @relation(fields: [planId], references: [id])
  transactions OrganizationTransaction[]

  @@index([organizationId, status])
  @@index([status, endDate]) // expiry sweep
  @@map("organization_subscriptions")
}

model OrganizationTransaction {
  id                String               @id @default(cuid())
  organizationId    String
  subscriptionId    String?
  type              OrgTransactionType
  status            OrgTransactionStatus @default(PENDING)
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("INR")
  razorpayOrderId   String?              @unique
  razorpayPaymentId String?
  razorpayRefundId  String?              @unique

  // Refund tracking lives on the ORIGINAL transaction; a separate REFUND-type
  // row is also written on success as the negative-flow ledger entry.
  refundAmount Decimal?         @db.Decimal(10, 2)
  refundReason String?          @db.Text
  refundStatus OrgRefundStatus?
  refundedAt   DateTime?
  refundedById String? // platform admin userId (no FK to keep User untouched)

  paidByUserId String? // who completed the payment
  notes        Json? // plan snapshot { planName, billingCycle, periodStart, periodEnd }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription OrganizationSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId, createdAt])
  @@index([status, type])
  @@map("organization_transactions")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String? // null for Supabase Auth users (password stored in auth.users)
  avatar       String?
  bio          String?       @db.Text
  headline     String?
  website      String?
  role         Role          @default(STUDENT)
  // Sub-role for admins — null for non-admins. Defaults to SUPER_ADMIN
  // when a user is first promoted to ADMIN (see /api/admin/admins/[id]/sub-role).
  adminSubRole AdminSubRole?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Instructor approval workflow
  instructorStatus       InstructorStatus?
  instructorAppliedAt    DateTime?
  instructorReviewedAt   DateTime?
  instructorRejectReason String?           @db.Text

  organizations OrganizationMember[]
  courses       Course[]             @relation("CourseInstructor")
  enrollments   Enrollment[]
  orders        Order[]

  reviews        Review[]
  wishlist       Wishlist[]
  notifications  Notification[]
  certificates   Certificate[]
  quizAttempts   QuizAttempt[]
  lessonProgress LessonProgress[]
  couponUses     CouponUse[]
  highlights     Highlight[]
  blogs          Blog[]           @relation("BlogAuthor")
  gameProfile    UserGameProfile?
  userBadges     UserBadge[]
  xpEvents       XpEvent[]

  // Tour Flags
  hasSeenTour          Boolean @default(false)
  hasSeenCommunityTour Boolean @default(false)

  // Onboarding
  hasCompletedOnboarding           Boolean  @default(false)
  hasCompletedInstructorOnboarding Boolean  @default(false)
  teachingTopics                   String[] @default([])

  // Feature add-on purchases
  featurePurchases FeaturePurchase[]

  // Professions
  professions UserProfession[]

  // Revenue sharing
  instructorWallet InstructorWallet?
  payoutRequests   PayoutRequest[]
  referralLinks    ReferralLink[]

  // Refunds
  refundRequests RefundRequest[]
  adminRefunds   RefundRequest[] @relation("RefundAdmin")

  // Community
  forumThreads          ForumThread[]
  forumReplies          ForumReply[]
  forumVotes            ForumVote[]
  forumReactions        ForumReaction[]
  forumBookmarks        ForumBookmark[]
  studyGroups           StudyGroupMember[]
  createdGroups         StudyGroup[]           @relation("GroupCreator")
  peerReviewSubmissions PeerReviewAssignment[]
  peerReviews           PeerReview[]
  activityEvents        ActivityFeedEvent[]
  groupNotes            GroupNote[]
  groupJoinRequests     GroupJoinRequest[]

  // Media Library
  mediaAssets MediaAsset[]

  // Instructor follows (student → instructor)
  followedInstructors UserInstructorFollow[] @relation("StudentFollows")
  followers           UserInstructorFollow[] @relation("InstructorFollowers")

  // Class / Cohort management
  classesOwned          Class[]                @relation("ClassInstructor")
  classAssistantships   ClassAssistant[]
  classEnrollments      ClassEnrollment[]
  liveSessionsHosted    LiveSession[]          @relation("LiveSessionHost")
  attendanceRecords     Attendance[]
  announcements         Announcement[]         @relation("AnnouncementAuthor")
  discussions           Discussion[]           @relation("DiscussionAuthor")
  classMessages         Message[]              @relation("MessageAuthor")
  discussionVotes       DiscussionVote[]
  classXpEvents         ClassXpEvent[]
  classCertificates     ClassCertificate[]
  assignmentsCreated    Assignment[]           @relation("AssignmentAuthor")
  assignmentSubmissions AssignmentSubmission[] @relation("AssignmentSubmitter")
  assignmentsGraded     AssignmentSubmission[] @relation("AssignmentGrader")

  // Course Playlists
  coursePlaylists CoursePlaylist[]       @relation("PlaylistOwner")
  playlistFollows CoursePlaylistFollow[]

  // Books module
  books         Book[]         @relation("BookAuthor")
  bookOrders    BookOrder[]
  bookPurchases BookPurchase[]
  bookReviews   BookReview[]
  bookWishlist  BookWishlist[]
  cart          Cart?

  // Course collaboration
  courseCollaborations   CourseCollaborator[]        @relation("CourseCollaboratorUser")
  courseCollabsAddedByMe CourseCollaborator[]        @relation("CourseCollaboratorAddedBy")
  courseInvitesSent      CourseCollaborationInvite[] @relation("CourseInviteSender")
  courseActivityLogs     CourseActivityLog[]         @relation("CourseActivityLogUser")

  // Whiteboards
  whiteboardsOwned        Whiteboard[]             @relation("WhiteboardOwner")
  whiteboardCollaborations WhiteboardCollaborator[]

  @@map("users")
}

// ─── Category & Tag ───────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  icon    String?
  color   String?
  courses Course[]
  books   Book[]

  @@map("categories")
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  courses CourseTag[]

  @@map("tags")
}

model CourseTag {
  courseId String
  tagId    String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

// ─── Course ───────────────────────────────────────────────────────────────────

model Course {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String        @db.Text
  shortDesc     String?
  thumbnail     String?
  previewVideo  String?
  status        ContentStatus @default(DRAFT)
  price         Decimal?      @db.Decimal(10, 2)
  discountPrice Decimal?      @db.Decimal(10, 2)
  isFree        Boolean       @default(false)

  level                    String   @default("beginner")
  language                 String   @default("English")
  totalDuration            Int      @default(0)
  totalLessons             Int      @default(0)
  // Revenue split: instructor gets this %, platform gets (100 - instructorRevenuePercent)%
  // Configurable per-course (default 70). Valid range: 70–80.
  instructorRevenuePercent Int      @default(70)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  categoryId     String?
  createdById    String
  organizationId String?

  category     Category?     @relation(fields: [categoryId], references: [id])
  createdBy    User          @relation("CourseInstructor", fields: [createdById], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  sections       Section[]
  lessons        Lesson[]
  enrollments    Enrollment[]
  reviews        Review[]
  tags           CourseTag[]
  orders         Order[]
  wishlist       Wishlist[]
  certificates   Certificate[]
  referralLinks  ReferralLink[]
  refundRequests RefundRequest[]
  classCourses   ClassCourse[]
  playlistItems  CoursePlaylistItem[]
  collaborators  CourseCollaborator[]
  collabInvites  CourseCollaborationInvite[]
  activityLogs   CourseActivityLog[]

  @@index([organizationId, status])
  @@map("courses")
}

// ─── Course Collaborator (course ↔ instructor mapping) ────────────────────────

model CourseCollaborator {
  id           String                 @id @default(cuid())
  courseId     String
  userId       String
  role         CourseCollaboratorRole @default(CO_INSTRUCTOR)
  // Configurable revenue share (percent of the instructor pool, 0-100). The
  // sum of revenueShare across active collaborators (incl. OWNER) should
  // equal 100 — validated at the service layer.
  revenueShare Decimal                @default(0) @db.Decimal(5, 2)
  // Whether this collaborator should be shown publicly on the course page.
  isPublic     Boolean                @default(true)
  addedById    String? // who invited / added this collaborator
  acceptedAt   DateTime? // null until the user accepts an invite
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user    User   @relation("CourseCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy User?  @relation("CourseCollaboratorAddedBy", fields: [addedById], references: [id])

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId, role])
  @@map("course_collaborators")
}

// ─── Course Collaboration Invite ──────────────────────────────────────────────
// Outstanding invite (by email) — supports inviting users that don't yet
// have an account. Resolved to a CourseCollaborator row on acceptance.

model CourseCollaborationInvite {
  id           String                    @id @default(cuid())
  courseId     String
  email        String
  token        String                    @unique
  role         CourseCollaboratorRole    @default(CO_INSTRUCTOR)
  revenueShare Decimal                   @default(0) @db.Decimal(5, 2)
  invitedById  String
  status       CollaborationInviteStatus @default(PENDING)
  message      String?                   @db.Text
  expiresAt    DateTime
  acceptedAt   DateTime?
  declinedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("CourseInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([courseId, status])
  @@index([email, status])
  @@map("course_collaboration_invites")
}

// ─── Course Activity Log ──────────────────────────────────────────────────────
// Append-only audit log of mutations performed on a course by any
// instructor (owner or collaborator). Used by the collaboration UI and
// the admin monitoring view.

model CourseActivityLog {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  action    String // e.g. "course.updated", "lesson.created", "collaborator.added"
  meta      Json?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation("CourseActivityLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
  @@index([userId])
  @@map("course_activity_logs")
}

// ─── Section ──────────────────────────────────────────────────────────────────

model Section {
  id       String @id @default(cuid())
  title    String
  order    Int
  courseId String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("sections")
}

// ─── Lesson ───────────────────────────────────────────────────────────────────

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  type        LessonType @default(TEXT)
  content     String?    @db.Text
  order       Int
  duration    Int?
  isFree      Boolean    @default(false)
  publishAt   DateTime? // drip: null = immediately available

  courseId  String
  sectionId String?

  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section    Section?         @relation(fields: [sectionId], references: [id])
  progress   LessonProgress[]
  quiz       Quiz?
  highlights Highlight[]

  @@map("lessons")
}

// ─── Enrollment ───────────────────────────────────────────────────────────────

model Enrollment {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  lastLessonId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─── Lesson Progress ──────────────────────────────────────────────────────────

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  watchedSecs Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ─── Quiz & Assessments ───────────────────────────────────────────────────────

model Quiz {
  id        String @id @default(cuid())
  lessonId  String @unique
  title     String
  passMark  Int    @default(70)
  timeLimit Int?

  lesson      Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   Question[]
  attempts    QuizAttempt[]
  assignments Assignment[]

  @@map("quizzes")
}

model Question {
  id      String @id @default(cuid())
  quizId  String
  text    String @db.Text
  options Json
  order   Int
  points  Int    @default(1)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  answers   Json
  timeTaken Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?  @db.Text
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("reviews")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
  @@map("wishlists")
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Order {
  id                    String      @id @default(cuid())
  userId                String
  courseId              String?
  // Feature add-on purchase (mutually exclusive with courseId)
  featureId             String?
  amount                Decimal     @db.Decimal(10, 2)
  currency              String      @default("INR")
  status                OrderStatus @default(PENDING)
  // Razorpay payment fields
  razorpayOrderId       String?     @unique
  razorpayPaymentId     String?     @unique
  couponId              String?
  discountAmount        Decimal?    @db.Decimal(10, 2)
  // Platform-wide auto-applied offer (separate from coupon code)
  platformOfferId       String?
  platformOfferDiscount Decimal?    @db.Decimal(10, 2)
  // Processing fee added on top of the goods total (included in `amount`)
  processingFee         Decimal?    @db.Decimal(10, 2)
  // Revenue attribution (populated on PAID status)
  instructorRevenue     Decimal?    @db.Decimal(10, 2)
  platformRevenue       Decimal?    @db.Decimal(10, 2)
  // Dynamic revenue split tracking
  saleSource            SaleSource  @default(ORGANIC)
  instructorPercent     Decimal?    @db.Decimal(5, 2) // actual % applied (70 | 85 | 90)
  referralLinkId        String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  course             Course?             @relation(fields: [courseId], references: [id])
  coupon             Coupon?             @relation(fields: [couponId], references: [id])
  platformOffer      PlatformOffer?      @relation(fields: [platformOfferId], references: [id], onDelete: SetNull)
  feature            PlatformFeature?    @relation(fields: [featureId], references: [id])
  featurePurchase    FeaturePurchase?
  referralLink       ReferralLink?       @relation(fields: [referralLinkId], references: [id])
  walletTransactions WalletTransaction[]
  refundRequest      RefundRequest?
  ledgerEntries      LedgerEntry[]

  @@map("orders")
}

model Payout {
  id             String    @id @default(cuid())
  organizationId String
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @default("INR")
  status         String    @default("PENDING")
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("payouts")
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType @default(PERCENTAGE)
  discount       Decimal      @db.Decimal(10, 2)
  maxUses        Int?
  uses           Int          @default(0)
  expiresAt      DateTime?
  courseId       String?
  bookId         String? // scope coupon to a single book (symmetric with courseId)
  organizationId String?
  createdById    String? // instructor who created this coupon
  createdAt      DateTime     @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  orders       Order[]
  bookOrders   BookOrder[]
  couponUses   CouponUse[]

  @@map("coupons")
}

model CouponUse {
  userId   String
  couponId String
  usedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  coupon Coupon @relation(fields: [couponId], references: [id])

  @@id([userId, couponId])
  @@map("coupon_uses")
}

// ─── Certificate ──────────────────────────────────────────────────────────────

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  certificateUrl String?
  issuedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String    @db.Text
  type      NotifType @default(SYSTEM)
  read      Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model Blog {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  excerpt   String?       @db.Text
  content   String        @db.Text
  thumbnail String?
  status    ContentStatus @default(DRAFT)
  tags      String? // comma-separated tags
  readTime  Int? // estimated reading time in minutes
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  authorId String
  author   User   @relation("BlogAuthor", fields: [authorId], references: [id])

  @@map("blogs")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model UserGameProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  xp             Int       @default(0)
  level          Int       @default(1)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_game_profiles")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xp        Int
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("xp_events")
}

// ─── Highlight ────────────────────────────────────────────────────────────────

model Highlight {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  text        String   @db.Text
  blockIndex  Int
  startOffset Int
  endOffset   Int
  color       String   @default("#a855f7")
  note        String?  @db.Text
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@map("highlights")
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id          String    @id @default(cuid())
  name        String
  email       String
  subject     String?
  message     String    @db.Text
  status      String    @default("UNREAD") // UNREAD, READ, REPLIED
  adminReply  String?   @db.Text
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("contact_messages")
}

// ─── Demo Requests ─────────────────────────────────────────────────────────────

enum DemoRequestStatus {
  PENDING
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

model DemoRequest {
  id                String            @id @default(cuid())
  name              String
  email             String
  phone             String?
  organization      String
  jobTitle          String?
  teamSize          String?
  interests         String[]          @default([])
  preferredDate     DateTime?
  preferredTimeSlot String?
  timezone          String?
  message           String?           @db.Text
  source            String?
  status            DemoRequestStatus @default(PENDING)
  scheduledAt       DateTime?
  meetingLink       String?
  adminNotes        String?           @db.Text
  handledById       String?
  contactedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@map("demo_requests")
}

// ─── Community: Discussion Forums ─────────────────────────────────────────────

model ForumThread {
  id              String   @id @default(cuid())
  title           String
  body            String   @db.Text
  courseId        String?
  lessonId        String?
  authorId        String
  isPinned        Boolean  @default(false)
  isResolved      Boolean  @default(false)
  acceptedReplyId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies       ForumReply[]
  acceptedReply ForumReply?     @relation("AcceptedReply", fields: [acceptedReplyId], references: [id], onDelete: SetNull)
  bookmarks     ForumBookmark[]

  @@index([courseId])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumReply {
  id        String   @id @default(cuid())
  body      String   @db.Text
  threadId  String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread           ForumThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author           User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent           ForumReply?     @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children         ForumReply[]    @relation("ReplyToReply")
  votes            ForumVote[]
  reactions        ForumReaction[]
  acceptedInThread ForumThread?    @relation("AcceptedReply")

  @@index([threadId])
  @@index([authorId])
  @@map("forum_replies")
}

model ForumVote {
  id      String @id @default(cuid())
  userId  String
  replyId String
  value   Int // +1 or -1

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@map("forum_votes")
}

model ForumReaction {
  id        String   @id @default(cuid())
  userId    String
  replyId   String
  emoji     String // one of a fixed client-side set
  createdAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId, emoji])
  @@index([replyId])
  @@map("forum_reactions")
}

model ForumBookmark {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([userId])
  @@map("forum_bookmarks")
}

// ─── Community: Study Groups ──────────────────────────────────────────────────

model StudyGroup {
  id               String   @id @default(cuid())
  name             String
  description      String?  @db.Text
  courseId         String?
  inviteCode       String   @unique
  maxMembers       Int      @default(20)
  isPublic         Boolean  @default(true)
  requiresApproval Boolean  @default(false)
  groupXp          Int      @default(0)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy    User               @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      StudyGroupMember[]
  notes        GroupNote[]
  joinRequests GroupJoinRequest[]

  @@index([courseId])
  @@map("study_groups")
}

model StudyGroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("study_group_members")
}

model GroupJoinRequest {
  id        String            @id @default(cuid())
  groupId   String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  message   String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_join_requests")
}

model GroupNote {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_notes")
}

// ─── Community: Peer Review ───────────────────────────────────────────────────

model PeerReviewAssignment {
  id            String   @id @default(cuid())
  title         String
  content       String   @db.Text
  courseId      String?
  lessonId      String?
  submittedById String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  submittedBy User         @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  reviews     PeerReview[]

  @@index([submittedById])
  @@map("peer_review_assignments")
}

model PeerReview {
  id           String   @id @default(cuid())
  assignmentId String
  reviewerId   String
  rating       Int // 1-5
  feedback     String   @db.Text
  rubricScores Json? // { clarity: 4, depth: 3, ... }
  createdAt    DateTime @default(now())

  assignment PeerReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer   User                 @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, reviewerId])
  @@map("peer_reviews")
}

// ─── Community: Activity Feed ─────────────────────────────────────────────────

model ActivityFeedEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String // BADGE_EARNED, COURSE_COMPLETED, THREAD_CREATED, GROUP_JOINED, REVIEW_SUBMITTED
  title       String
  description String?  @db.Text
  meta        Json? // extra data (badgeName, courseName, etc.)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_feed_events")
}

// ─── Platform Features (purchasable add-ons) ──────────────────────────────────

model PlatformFeature {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases FeaturePurchase[]
  orders    Order[]

  @@map("platform_features")
}

model FeaturePurchase {
  id          String   @id @default(cuid())
  userId      String
  featureId   String
  // Nullable: allows admin-granted access without an order
  orderId     String?  @unique
  purchasedAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id])
  order   Order?          @relation(fields: [orderId], references: [id])

  @@unique([userId, featureId])
  @@map("feature_purchases")
}

// ─── Launch: Waitlist ─────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("waitlist_entries")
}

// ─── Profession System ────────────────────────────────────────────────────────

model Profession {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  icon           String // emoji or lucide icon name
  color          String   @default("orange")
  courseKeywords String[] // category slugs / tag names used for recommendations
  isDefault      Boolean  @default(true) // predefined by platform
  isActive       Boolean  @default(true) // admin can hide without deleting
  order          Int      @default(0) // display sort order
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users UserProfession[]

  @@map("professions")
}

model UserProfession {
  id           String   @id @default(cuid())
  userId       String
  professionId String? // null for custom profession entries
  customName   String? // non-null when professionId is null (custom)
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession Profession? @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([userId, professionId]) // prevent duplicate standard professions per user
  @@map("user_professions")
}

// ─── Revenue Sharing ──────────────────────────────────────────────────────────

model ReferralLink {
  id           String   @id @default(cuid())
  instructorId String
  code         String   @unique
  courseId     String? // null = applies to all instructor's courses
  label        String? // human-readable label
  totalClicks  Int      @default(0)
  conversions  Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  instructor User    @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  course     Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  orders     Order[]

  @@map("referral_links")
}

model InstructorWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Decimal  @default(0) @db.Decimal(12, 2) // available for payout
  totalEarned    Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   WalletTransaction[]
  payoutRequests PayoutRequest[]

  @@map("instructor_wallets")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  orderId     String?
  amount      Decimal  @db.Decimal(12, 2)
  type        String // CREDIT | DEBIT | PAYOUT_REQUEST | PAYOUT_PROCESSED
  description String
  meta        Json? // { courseTitle, saleSource, instructorPercent }
  createdAt   DateTime @default(now())

  wallet InstructorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order  Order?           @relation(fields: [orderId], references: [id])

  @@map("wallet_transactions")
}

// ─── Refund Requests ─────────────────────────────────────────────────────────

model RefundRequest {
  id       String @id @default(cuid())
  orderId  String @unique // one refund request per order (idempotency)
  userId   String
  courseId String

  // Snapshot at request-creation time (immutable after creation)
  progressPercent  Decimal @db.Decimal(5, 2) // 0.00–100.00
  completedLessons Int
  totalLessons     Int

  // Financial breakdown (pre-calculated, stored immutably)
  originalAmount Decimal @db.Decimal(10, 2) // order amount
  refundPercent  Decimal @db.Decimal(5, 2) // 100 - progressPercent
  refundAmount   Decimal @db.Decimal(10, 2) // amount to refund to student
  instructorLoss Decimal @db.Decimal(10, 2) // deducted from instructor wallet
  platformLoss   Decimal @db.Decimal(10, 2) // platform revenue loss

  status     RefundStatus @default(PENDING)
  reason     String?      @db.Text // student's reason
  adminNotes String?      @db.Text // admin review notes
  adminId    String? // who approved/rejected

  razorpayRefundId String? @unique // Razorpay refund ID (set on PROCESSED)

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime? // when admin acted
  processedAt DateTime? // when refund completed

  order  Order  @relation(fields: [orderId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  admin  User?  @relation("RefundAdmin", fields: [adminId], references: [id])

  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("refund_requests")
}

// ─── Financial Ledger ─────────────────────────────────────────────────────────

model LedgerEntry {
  id              String  @id @default(cuid())
  orderId         String?
  refundRequestId String?
  userId          String // the student involved
  courseId        String?

  type        LedgerEntryType
  amount      Decimal         @db.Decimal(10, 2)
  description String
  meta        Json? // extra context (progress %, splits, etc.)

  createdAt DateTime @default(now())

  order         Order?         @relation(fields: [orderId], references: [id])
  refundRequest RefundRequest? @relation(fields: [refundRequestId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([courseId])
  @@index([type])
  @@map("ledger_entries")
}

// ─── Media Library ────────────────────────────────────────────────────────────

model MediaAsset {
  id        String   @id @default(cuid())
  userId    String
  url       String
  publicId  String   @unique
  folder    String   @default("misc") // courses | blogs | avatars | books | misc
  kind      String   @default("image") // image | document | video
  filename  String?
  bytes     Int      @default(0)
  width     Int      @default(0)
  height    Int      @default(0)
  format    String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, folder])
  @@index([userId, kind])
  @@map("media_assets")
}

model PayoutRequest {
  id           String       @id @default(cuid())
  walletId     String
  instructorId String
  amount       Decimal      @db.Decimal(12, 2)
  currency     String       @default("INR")
  status       PayoutStatus @default(PENDING)
  bankDetails  Json? // { accountNumber, ifsc, bankName, accountHolder }
  notes        String?      @db.Text // instructor notes
  adminNotes   String?      @db.Text // admin notes on approve/reject
  requestedAt  DateTime     @default(now())
  processedAt  DateTime?

  // Razorpay Route tracking
  razorpayLinkedAccountId String? // Route linked account (acc_xxx) — reused across requests
  razorpayTransferId      String? @unique // Route transfer ID (trf_xxx)
  razorpayTransferStatus  String? // pending | on_hold | settled

  wallet     InstructorWallet @relation(fields: [walletId], references: [id])
  instructor User             @relation(fields: [instructorId], references: [id])

  @@map("payout_requests")
}

// ─── Email Templates & Logs ───────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  subject     String
  htmlBody    String   @db.Text
  description String?
  variables   String[] // e.g. ["name", "email", "courseTitle"]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs EmailLog[]

  @@map("email_templates")
}

model EmailLog {
  id           String         @id @default(cuid())
  to           String
  subject      String
  templateId   String?
  templateName String? // snapshot of template name at send time
  status       EmailLogStatus @default(SENT)
  resendId     String?
  error        String?        @db.Text
  meta         Json? // extra context (userId, courseId, etc.)
  sentAt       DateTime       @default(now())

  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([status])
  @@index([sentAt])
  @@map("email_logs")
}

enum EmailLogStatus {
  SENT
  FAILED
  PENDING
}

// ─── Instructor Follow ────────────────────────────────────────────────────────

model UserInstructorFollow {
  id           String   @id @default(cuid())
  userId       String
  instructorId String
  createdAt    DateTime @default(now())

  user       User @relation("StudentFollows", fields: [userId], references: [id], onDelete: Cascade)
  instructor User @relation("InstructorFollowers", fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([userId, instructorId])
  @@map("user_instructor_follows")
}

// ─── Class / Cohort Management ────────────────────────────────────────────────

enum ClassVisibility {
  PUBLIC
  PRIVATE
}

enum ClassJoinMode {
  OPEN
  APPROVAL_REQUIRED
  INVITE_ONLY
}

enum ClassStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ClassEnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
  WAITLISTED
}

enum ClassMemberRole {
  STUDENT
  ASSISTANT
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum DiscussionKind {
  GENERAL
  QUESTION
  ANNOUNCEMENT_REPLY
}

enum ClassCertificateType {
  COMPLETION
  ATTENDANCE
}

enum AssignmentType {
  TEXT // Long-form written response
  FILE // File upload (PDF, doc, zip, etc.)
  URL // Link submission (e.g., GitHub repo, deployed site)
  QUIZ // Auto-graded quiz reference
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  DRAFT // Saved but not submitted
  SUBMITTED // Awaiting grading
  GRADED // Reviewed with score/feedback
  RETURNED // Sent back for revision
}

model Class {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?         @db.Text
  thumbnail   String?
  banner      String?
  visibility  ClassVisibility @default(PUBLIC)
  joinMode    ClassJoinMode   @default(OPEN)
  status      ClassStatus     @default(DRAFT)
  inviteCode  String?         @unique
  maxStudents Int?
  startDate   DateTime?
  endDate     DateTime?
  price       Decimal?        @db.Decimal(10, 2)
  isPaid      Boolean         @default(false)

  // Feature flags
  enableChat        Boolean @default(true)
  enableDiscussion  Boolean @default(true)
  enableAttendance  Boolean @default(false)
  enableLiveClass   Boolean @default(false)
  enableLeaderboard Boolean @default(true)
  enableCertificate Boolean @default(true)

  // Requirements for certificate (percentages 0-100)
  certCompletionPercent Int @default(100)
  certAttendancePercent Int @default(0)

  instructorId String
  instructor   User   @relation("ClassInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  courses       ClassCourse[]
  enrollments   ClassEnrollment[]
  assistants    ClassAssistant[]
  liveSessions  LiveSession[]
  announcements Announcement[]
  discussions   Discussion[]
  messages      Message[]
  xpEvents      ClassXpEvent[]
  certificates  ClassCertificate[]
  assignments   Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([status, visibility])
  @@map("classes")
}

model ClassCourse {
  id              String  @id @default(cuid())
  classId         String
  courseId        String
  order           Int     @default(0)
  isRequired      Boolean @default(true)
  // Drip: number of days after enrollment when course unlocks (null = immediate)
  unlockAfterDays Int?

  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([classId, courseId])
  @@index([classId, order])
  @@map("class_courses")
}

model ClassEnrollment {
  id           String                @id @default(cuid())
  classId      String
  userId       String
  status       ClassEnrollmentStatus @default(APPROVED)
  role         ClassMemberRole       @default(STUDENT)
  requestedAt  DateTime              @default(now())
  approvedAt   DateTime?
  rejectedAt   DateTime?
  bannedAt     DateTime?
  completedAt  DateTime?
  // Cached progress metrics
  progressPct  Int                   @default(0)
  xpEarned     Int                   @default(0)
  attendStreak Int                   @default(0)
  lastActiveAt DateTime?

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId, status])
  @@index([userId])
  @@map("class_enrollments")
}

model ClassAssistant {
  id        String   @id @default(cuid())
  classId   String
  userId    String
  createdAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@map("class_assistants")
}

model LiveSession {
  id           String            @id @default(cuid())
  classId      String
  hostId       String
  title        String
  description  String?           @db.Text
  scheduledAt  DateTime
  duration     Int               @default(60) // minutes
  meetingUrl   String?
  recordingUrl String?
  status       LiveSessionStatus @default(SCHEDULED)
  startedAt    DateTime?
  endedAt      DateTime?

  class      Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  host       User         @relation("LiveSessionHost", fields: [hostId], references: [id])
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId, scheduledAt])
  @@map("live_sessions")
}

model Attendance {
  id        String           @id @default(cuid())
  sessionId String
  userId    String
  status    AttendanceStatus @default(PRESENT)
  joinedAt  DateTime?
  leftAt    DateTime?
  notes     String?

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("class_attendance")
}

model Announcement {
  id        String   @id @default(cuid())
  classId   String
  authorId  String
  title     String
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class  Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  author User  @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([classId, createdAt])
  @@map("class_announcements")
}

model Discussion {
  id              String         @id @default(cuid())
  classId         String
  authorId        String
  kind            DiscussionKind @default(GENERAL)
  title           String
  body            String         @db.Text
  parentId        String?
  resolved        Boolean        @default(false)
  pinned          Boolean        @default(false)
  tags            String[]       @default([])
  // For QUESTION threads: which reply was accepted as the answer.
  acceptedReplyId String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  class         Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  author        User             @relation("DiscussionAuthor", fields: [authorId], references: [id])
  parent        Discussion?      @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Discussion[]     @relation("DiscussionReplies")
  acceptedReply Discussion?      @relation("DiscussionAcceptedReply", fields: [acceptedReplyId], references: [id], onDelete: SetNull)
  acceptedFor   Discussion?      @relation("DiscussionAcceptedReply")
  votes         DiscussionVote[]

  @@index([classId, createdAt])
  @@index([classId, pinned, createdAt])
  @@index([parentId])
  @@map("class_discussions")
}

model DiscussionVote {
  discussionId String
  userId       String
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([discussionId, userId])
  @@index([userId])
  @@map("class_discussion_votes")
}

model Message {
  id        String   @id @default(cuid())
  classId   String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  class  Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  author User  @relation("MessageAuthor", fields: [authorId], references: [id])

  @@index([classId, createdAt])
  @@map("class_messages")
}

model ClassXpEvent {
  id        String   @id @default(cuid())
  classId   String
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([classId, userId])
  @@map("class_xp_events")
}

model ClassCertificate {
  id             String               @id @default(cuid())
  classId        String
  userId         String
  type           ClassCertificateType
  issuedAt       DateTime             @default(now())
  certificateUrl String?

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId, type])
  @@map("class_certificates")
}

// ─── Assignments ──────────────────────────────────────────────────────────────
// Instructor-authored work given to students in a class. Each assignment can
// accept text, file, URL, or reference an existing Quiz. Submissions are
// per-student; instructors grade them with score + feedback.

model Assignment {
  id           String           @id @default(cuid())
  classId      String
  authorId     String
  title        String
  description  String?          @db.Text
  instructions String?          @db.Text
  type         AssignmentType   @default(TEXT)
  status       AssignmentStatus @default(DRAFT)

  maxScore     Int @default(100)
  passingScore Int @default(60)
  weight       Int @default(1) // weighting in class grade rollup

  dueAt     DateTime?
  publishAt DateTime? // null = publish immediately on status change

  // For TYPE = QUIZ
  quizId String?

  // Submission rules
  allowLate   Boolean @default(true)
  latePenalty Int     @default(0) // % deducted per day late, 0-100
  maxAttempts Int     @default(1) // 0 = unlimited

  // Attachments (instructor-provided resource files)
  attachments String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  author      User                   @relation("AssignmentAuthor", fields: [authorId], references: [id])
  quiz        Quiz?                  @relation(fields: [quizId], references: [id], onDelete: SetNull)
  submissions AssignmentSubmission[]

  @@index([classId, status])
  @@index([classId, dueAt])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String @id @default(cuid())
  assignmentId String
  studentId    String

  status  SubmissionStatus @default(DRAFT)
  attempt Int              @default(1)

  // Submission content (one of these per type)
  textBody String?  @db.Text
  fileUrls String[] @default([])
  url      String?

  submittedAt DateTime?
  // Grading
  score       Int?
  feedback    String?   @db.Text
  graderId    String?
  gradedAt    DateTime?

  // Convenience flag — recomputed on grade
  isLate Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("AssignmentSubmitter", fields: [studentId], references: [id], onDelete: Cascade)
  grader     User?      @relation("AssignmentGrader", fields: [graderId], references: [id])

  @@unique([assignmentId, studentId, attempt])
  @@index([assignmentId, status])
  @@index([studentId])
  @@map("assignment_submissions")
}

// ─── Course Playlists ─────────────────────────────────────────────────────────
// YouTube-style curated course lists. Created by instructors/admins to organize
// courses by topic, learning path, category, or skill level. Students can
// follow/save public playlists.

model CoursePlaylist {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  description String?            @db.Text
  coverImage  String?
  visibility  PlaylistVisibility @default(PUBLIC)
  ownerId     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  owner     User                   @relation("PlaylistOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  items     CoursePlaylistItem[]
  followers CoursePlaylistFollow[]

  @@index([ownerId])
  @@index([visibility, createdAt])
  @@map("course_playlists")
}

model CoursePlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  courseId   String
  order      Int      @default(0)
  addedAt    DateTime @default(now())

  playlist CoursePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([playlistId, courseId])
  @@index([playlistId, order])
  @@map("course_playlist_items")
}

model CoursePlaylistFollow {
  userId     String
  playlistId String
  createdAt  DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist CoursePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([playlistId])
  @@map("course_playlist_follows")
}

// ─── Books / Documents Module ─────────────────────────────────────────────────

model Book {
  id                       String         @id @default(cuid())
  title                    String
  slug                     String         @unique
  description              String         @db.Text
  shortDesc                String?
  coverImage               String?
  previewVideo             String?
  author                   String
  pageCount                Int?
  language                 String         @default("English")
  fileFormat               BookFileFormat
  fileUrl                  String
  filePublicId             String
  fileSize                 Int
  price                    Decimal?       @db.Decimal(10, 2)
  discountPrice            Decimal?       @db.Decimal(10, 2)
  isFree                   Boolean        @default(false)
  status                   ContentStatus  @default(DRAFT)
  instructorRevenuePercent Int            @default(70)
  categoryId               String?
  createdById              String
  organizationId           String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  category     Category?       @relation(fields: [categoryId], references: [id])
  createdBy    User            @relation("BookAuthor", fields: [createdById], references: [id])
  organization Organization?   @relation(fields: [organizationId], references: [id])
  orderItems   BookOrderItem[]
  purchases    BookPurchase[]
  reviews      BookReview[]
  wishlist     BookWishlist[]
  cartItems    CartItem[]

  @@index([status, createdAt])
  @@index([categoryId, status])
  @@index([createdById])
  @@map("books")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  cartId  String
  bookId  String
  addedAt DateTime @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([cartId, bookId])
  @@index([bookId])
  @@map("cart_items")
}

model BookOrder {
  id                    String      @id @default(cuid())
  userId                String
  amount                Decimal     @db.Decimal(10, 2)
  subtotal              Decimal     @db.Decimal(10, 2)
  currency              String      @default("INR")
  status                OrderStatus @default(PENDING)
  // Razorpay payment fields
  razorpayOrderId       String?     @unique
  razorpayPaymentId     String?     @unique
  couponId              String?
  discountAmount        Decimal?    @db.Decimal(10, 2)
  // Platform-wide auto-applied offer (separate from coupon code)
  platformOfferId       String?
  platformOfferDiscount Decimal?    @db.Decimal(10, 2)
  // Processing fee added on top of the goods total (included in `amount`)
  processingFee         Decimal?    @db.Decimal(10, 2)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user          User            @relation(fields: [userId], references: [id])
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  platformOffer PlatformOffer?  @relation(fields: [platformOfferId], references: [id], onDelete: SetNull)
  items         BookOrderItem[]

  @@index([userId, status])
  @@map("book_orders")
}

model BookOrderItem {
  id                String  @id @default(cuid())
  bookOrderId       String
  bookId            String
  price             Decimal @db.Decimal(10, 2)
  instructorRevenue Decimal @db.Decimal(10, 2)
  platformRevenue   Decimal @db.Decimal(10, 2)
  instructorPercent Decimal @db.Decimal(5, 2)

  bookOrder BookOrder     @relation(fields: [bookOrderId], references: [id], onDelete: Cascade)
  book      Book          @relation(fields: [bookId], references: [id])
  purchase  BookPurchase?

  @@unique([bookOrderId, bookId])
  @@index([bookId])
  @@map("book_order_items")
}

model BookPurchase {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  orderItemId String   @unique
  downloads   Int      @default(0)
  purchasedAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book          @relation(fields: [bookId], references: [id])
  orderItem BookOrderItem @relation(fields: [orderItemId], references: [id])

  @@unique([userId, bookId])
  @@index([userId, purchasedAt])
  @@map("book_purchases")
}

model BookReview {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, createdAt])
  @@map("book_reviews")
}

model BookWishlist {
  userId  String
  bookId  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([userId, bookId])
  @@index([bookId])
  @@map("book_wishlists")
}

// ─── Platform Offer ──────────────────────────────────────────────────────────
// Site-wide promotional discount auto-applied at checkout, plus the
// promotional banner shown on the landing page when the offer is active.
// Only one offer should be ACTIVE at a time; if multiple are active, the
// one with the highest `priority` wins (ties broken by most recent).
model PlatformOffer {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal      @db.Decimal(10, 2)
  // Optional cap on the discount when discountType = PERCENTAGE
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  // Optional minimum subtotal (in INR) required to apply
  minCartValue  Decimal?     @db.Decimal(10, 2)
  // What the offer applies to
  scope         OfferScope   @default(ALL)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean      @default(true)
  priority      Int          @default(0)

  // Landing-page banner controls
  bannerEnabled   Boolean @default(true)
  bannerCtaText   String  @default("Explore Courses")
  bannerCtaUrl    String  @default("/courses")
  bannerBgColor   String  @default("#d97757")
  bannerTextColor String  @default("#ffffff")

  // Last time the admin pushed an announcement email + in-app notification
  // to users about this offer. Used to disable the button once sent and to
  // display "Sent on …" in the admin list.
  notifiedAt    DateTime?
  notifiedCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  bookOrders BookOrder[]

  @@index([isActive, priority])
  @@map("platform_offers")
}

// ─── Whiteboard module ──────────────────────────────────────────────────────

enum WhiteboardScope {
  LIVE_CLASS
  COURSE
  LESSON
  ASSIGNMENT
  STUDENT_NOTE
  GROUP_PROJECT
  STANDALONE
}

enum WhiteboardRole {
  OWNER
  EDITOR
  VIEWER
}

model Whiteboard {
  id          String          @id @default(cuid())
  title       String          @default("Untitled whiteboard")
  scope       WhiteboardScope @default(STANDALONE)
  // Default role granted to LMS-context members who are not explicit collaborators.
  defaultRole WhiteboardRole  @default(VIEWER)

  ownerId String
  owner   User   @relation("WhiteboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Polymorphic LMS attachment — only one is set per board depending on scope.
  // Kept as plain scalar columns (not relations) so the board can attach to any
  // surface without forcing back-references onto every model.
  classId      String?
  courseId     String?
  lessonId     String?
  assignmentId String?
  studyGroupId String?

  pages         WhiteboardPage[]
  assets        WhiteboardAsset[]
  collaborators WhiteboardCollaborator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([scope, classId])
  @@index([scope, courseId])
  @@index([scope, lessonId])
  @@index([scope, assignmentId])
  @@index([scope, studyGroupId])
  @@map("whiteboards")
}

model WhiteboardPage {
  id           String  @id @default(cuid())
  whiteboardId String
  title        String  @default("Page 1")
  order        Int     @default(0)
  // Excalidraw appState subset (viewBackgroundColor, gridSize, …).
  appState     Json?

  whiteboard Whiteboard          @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  elements   WhiteboardElement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([whiteboardId, order])
  @@map("whiteboard_pages")
}

model WhiteboardElement {
  id          String  @id @default(cuid())
  pageId      String
  // Excalidraw element id — stable across edits, used for reconciliation.
  elementId   String
  type        String
  // Full serialized Excalidraw element (includes versionNonce for tie-breaks).
  data        Json
  // Excalidraw's monotonic version counter — higher wins on conflict.
  version     Int     @default(0)
  isDeleted   Boolean @default(false)
  updatedById String?

  page WhiteboardPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, elementId])
  @@index([pageId, isDeleted])
  @@map("whiteboard_elements")
}

model WhiteboardAsset {
  id           String  @id @default(cuid())
  whiteboardId String
  uploadedById String?
  // Excalidraw BinaryFile id — links an image element to its stored asset.
  fileId       String
  url          String
  publicId     String
  filename     String
  mimeType     String
  bytes        Int     @default(0)
  width        Int?
  height       Int?

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([whiteboardId, fileId])
  @@index([whiteboardId])
  @@map("whiteboard_assets")
}

model WhiteboardCollaborator {
  id           String         @id @default(cuid())
  whiteboardId String
  userId       String
  role         WhiteboardRole @default(VIEWER)
  invitedById  String?

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([whiteboardId, userId])
  @@index([userId])
  @@map("whiteboard_collaborators")
}
